#!/usr/bin/env bash
# git tidy — delete local branches that are fully merged into the default branch
# or have had no commits in the last 90 days.
set -e

default_branch="$(git config --get default-branch.name 2>/dev/null || echo "main")"
current="$(git symbolic-ref --short HEAD 2>/dev/null)"

# Cross-platform date: try GNU coreutils first, fall back to BSD (macOS)
if date -d '90 days ago' +%s &>/dev/null; then
  cutoff=$(date -d '90 days ago' +%s)
else
  cutoff=$(date -v-90d +%s)
fi

to_delete=()

for branch in $(git branch --format='%(refname:short)'); do
  [[ "$branch" == "$default_branch" || "$branch" == "$current" ]] && continue

  # Check if merged into default branch
  if git merge-base --is-ancestor "$branch" "$default_branch" 2>/dev/null; then
    to_delete+=("$branch")
    continue
  fi

  # Check if last commit is older than 90 days
  last_commit=$(git log -1 --format='%ct' "$branch" 2>/dev/null)
  if [[ -n "$last_commit" ]] && (( last_commit < cutoff )); then
    to_delete+=("$branch")
  fi
done

if (( ${#to_delete[@]} == 0 )); then
  echo "No merged or stale branches to clean up."
  exit 0
fi

echo "Branches to delete (merged into $default_branch or stale >90 days):"
printf '  %s\n' "${to_delete[@]}"
echo ""

read -r -p "Delete these branches? [y/N] " -n 1 answer
echo
[[ "$answer" =~ ^[Yy]$ ]] || exit 0

for branch in "${to_delete[@]}"; do
  git branch -D "$branch"
done
